// ══════════════════════════════════════════════════
// RENDER TASKS
// ══════════════════════════════════════════════════
function renderTasks() {
  const tasks = getTasks();
  const todayKey = getTodayKey();
  const completedIds = (userData && userData.days && userData.days[todayKey] && userData.days[todayKey].completedIds) || {};
  const list = document.getElementById('taskList');
  if (!list) return;

  list.innerHTML = tasks.map((task, idx) => {
    const done = completedIds[task.id];
    const locked = idx > 0 && !completedIds[tasks[idx-1].id] && idx !== 0;
    const badgeLabels = { easy:'সহজ', medium:'মাঝারি', hard:'কঠিন' };
    const isBonus = task.id === 't20';
    const canDoBonus = tasksCompleted >= 19;

    let btnHtml;
    if (done) {
      btnHtml = `<button class="task-btn task-btn-done">✅ সম্পন্ন</button>`;
    } else if (isBonus && !canDoBonus) {
      btnHtml = `<button class="task-btn task-btn-locked">🔒 ১৯টি শেষ করুন</button>`;
    } else {
      btnHtml = `<button class="task-btn task-btn-start" onclick="startTask('${task.id}',${task.earn},${task.duration},'${task.category}')">▶ শুরু করুন</button>`;
    }

    const earnDisplay = userLocation === 'US'
      ? `$${task.earn.toFixed(3)}`
      : `$${task.earn.toFixed(3)} <small>= ৳${Math.round(task.earn*exchangeRate)}</small>`;

    return `
    <div class="task-card ${done?'completed':''}">
      <span class="task-badge badge-${done?'done':task.badge}">${done?'✅ সম্পন্ন':badgeLabels[task.badge]}</span>
      <div class="task-icon">${task.icon}</div>
      <div class="task-title">${task.title}</div>
      <div class="task-desc">${task.desc}</div>
      <div class="task-footer">
        <div class="task-earn">${earnDisplay}</div>
        ${btnHtml}
      </div>
      ${task.duration>0?`<div class="task-timer" id="timer_${task.id}">⏱ সময়: ${task.duration}সে</div>`:''}
    </div>`;
  }).join('');
}

// ══════════════════════════════════════════════════
// START TASK
// ══════════════════════════════════════════════════
function startTask(taskId, earn, duration, category) {
  if (tasksCompleted >= DAILY_TASK_LIMIT) {
    showToast('⚠️ আজকের লিমিট শেষ! কাল আবার আসুন।');
    return;
  }

  // Open ad link for relevant categories
  if (category === 'popup' || category === 'browse') {
    window.open('https://www.profitablecpmratenetwork.com/nsjf8jk0?key=39084b7dc488e9371458306fda3464a2', '_blank');
  }

  // Start countdown
  const timerEl = document.getElementById('timer_' + taskId);
  let sec = duration || 5;
  if (timerEl) timerEl.style.color = '#ffc107';
  const iv = setInterval(() => {
    sec--;
    if (timerEl) timerEl.textContent = '⏱ অপেক্ষা করুন: ' + sec + 'সে';
    if (sec <= 0) {
      clearInterval(iv);
      completeTask(taskId, earn);
    }
  }, 1000);

  showToast('⏳ কাজ শুরু হয়েছে, অপেক্ষা করুন...');
}

async function completeTask(taskId, earn) {
  const todayKey = getTodayKey();
  const uid = currentUser.uid;
  try {
    await db.ref('users/' + uid).update({
      balance: firebase.database.ServerValue.increment(earn),
      totalEarned: firebase.database.ServerValue.increment(earn),
      totalTasks: firebase.database.ServerValue.increment(1),
      [`days/${todayKey}/earned`]: firebase.database.ServerValue.increment(earn),
      [`days/${todayKey}/tasks`]: firebase.database.ServerValue.increment(1),
      [`days/${todayKey}/completedIds/${taskId}`]: true,
    });
    await db.ref('transactions/' + uid).push({
      type: 'task', taskId, amount: earn,
      note: 'কাজ সম্পন্ন',
      timestamp: Date.now()
    });
    showToast('🎉 +$' + earn.toFixed(3) + ' ব্যালেন্সে যোগ হয়েছে!');
  } catch(e) {
    showToast('❌ সমস্যা হয়েছে, আবার চেষ্টা করুন');
  }
}

