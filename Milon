  firebase.auth().signOut();
}

// ══════════════════════════════════════════════════
// AUTH STATE
// ══════════════════════════════════════════════════
firebase.auth().onAuthStateChanged(async user => {
  if (user) {
    currentUser = user;
    await loadUser();
    showApp();
  } else {
    showAuth();
  }
});

async function loadUser() {
  const snap = await db.ref('users/' + currentUser.uid).once('value');
  userData = snap.val();
  const todayKey = getTodayKey();
  if (!userData.days) userData.days = {};
  if (!userData.days[todayKey]) {
    await db.ref('users/' + currentUser.uid + '/days/' + todayKey).set({ earned: 0, tasks: 0 });
    userData.days[todayKey] = { earned: 0, tasks: 0 };
  }
  // Listen for realtime updates
  db.ref('users/' + currentUser.uid).on('value', snap => {
    userData = snap.val();
    refreshUI();
  });
}

function showApp() {
  document.getElementById('authScreen').classList.remove('active');
  document.getElementById('appScreen').classList.add('active');
  detectLocation();
  renderTasks();
  loadHistory();
}

function showAuth() {
  document.getElementById('appScreen').classList.remove('active');
  document.getElementById('authScreen').classList.add('active');
}

// ══════════════════════════════════════════════════
// UI REFRESH
// ══════════════════════════════════════════════════
function refreshUI() {
  if (!userData) return;
  const todayKey = getTodayKey();
  const todayData = (userData.days && userData.days[todayKey]) || { earned:0, tasks:0 };
  tasksCompleted = todayData.tasks || 0;
  const todayEarned = todayData.earned || 0;
  const dailyLimit = userLocation === 'US' ? 50 : 10;
  const pct = Math.min(100, (tasksCompleted / DAILY_TASK_LIMIT) * 100);

  // Header
  const initials = (userData.name||'U').charAt(0).toUpperCase();
  document.getElementById('headerName').textContent = userData.name || '—';
  document.getElementById('headerAvatar').textContent = initials;
  document.getElementById('profileAv').textContent = initials;
  document.getElementById('profileName').textContent = userData.name || '—';
  document.getElementById('profilePhone').textContent = userData.phone || '—';
  document.getElementById('refCode').textContent = userData.refCode || '—';

  // Balance
  const bal = (userData.balance || 0).toFixed(2);
  const balBDT = ((userData.balance || 0) * exchangeRate).toFixed(0);
  document.getElementById('balanceAmount').textContent = '$' + bal;
  document.getElementById('balanceBDT').textContent = '= ৳' + Number(balBDT).toLocaleString('bn') + ' টাকা';
  document.getElementById('withdrawBalance').textContent = '$' + bal;
  document.getElementById('todayEarned').textContent = '$' + todayEarned.toFixed(2);
  document.getElementById('totalTasks').textContent = userData.totalTasks || 0;
  document.getElementById('refEarned').textContent = '$' + (userData.referralEarned||0).toFixed(2);

  // Progress
  document.getElementById('tasksDoneText').textContent = tasksCompleted + ' / ' + DAILY_TASK_LIMIT + ' কাজ সম্পন্ন';
  document.getElementById('limitPct').textContent = Math.round(pct) + '%';
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('myShare').textContent = '$' + (todayEarned * USER_SHARE).toFixed(2);

  // Profile stats
  document.getElementById('pTotalEarned').textContent = '$' + (userData.totalEarned||0).toFixed(2);
  document.getElementById('pTotalTasks').textContent = userData.totalTasks || 0;
  document.getElementById('pRefs').textContent = userData.referralCount || 0;

  // Update task states
  renderTasks();
}

