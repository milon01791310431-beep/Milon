<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EarnPro – কাজ করো, আয় করো</title>
<link href="https://fonts.googleapis.com/css2?family=Baloo+Da+2:wght@400;600;700;800&family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<!-- Firebase Compat -->
<script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-database-compat.js"></script>

<style>
:root {
  --primary: #00c853;
  --primary-dark: #009624;
  --accent: #ffd600;
  --bg: #0a0e1a;
  --card: #131929;
  --card2: #1a2235;
  --text: #e8eaf6;
  --muted: #7986cb;
  --danger: #ff1744;
  --gold: #ffc107;
  --radius: 16px;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: 'Poppins', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── Background ── */
body::before {
  content:'';
  position:fixed; inset:0;
  background: radial-gradient(ellipse at 20% 20%, rgba(0,200,83,.08) 0%, transparent 60%),
              radial-gradient(ellipse at 80% 80%, rgba(124,77,255,.07) 0%, transparent 60%);
  pointer-events:none; z-index:0;
}

/* ── SCREENS ── */
.screen { display:none; position:relative; z-index:1; min-height:100vh; }
.screen.active { display:block; }

/* ══════════════════════════════
   AUTH SCREEN
══════════════════════════════ */
#authScreen {
  display:flex; align-items:center; justify-content:center;
  padding:24px;
}

.auth-box {
  background: var(--card);
  border: 1px solid rgba(0,200,83,.2);
  border-radius: 24px;
  padding: 40px 32px;
  width: 100%; max-width: 420px;
  box-shadow: 0 20px 60px rgba(0,0,0,.5), 0 0 40px rgba(0,200,83,.05);
  animation: slideUp .5s ease;
}

@keyframes slideUp {
  from { opacity:0; transform:translateY(30px); }
  to   { opacity:1; transform:translateY(0); }
}

.logo-area {
  text-align:center; margin-bottom:32px;
}
.logo-icon {
  width:64px; height:64px; border-radius:20px;
  background: linear-gradient(135deg,#00c853,#00e676);
  display:flex; align-items:center; justify-content:center;
  font-size:28px; margin:0 auto 12px;
  box-shadow: 0 8px 24px rgba(0,200,83,.4);
}
.logo-area h1 {
  font-family:'Baloo Da 2',sans-serif;
  font-size:28px; font-weight:800;
  color:var(--primary); letter-spacing:1px;
}
.logo-area p { font-size:13px; color:var(--muted); margin-top:4px; }

.tabs {
  display:flex; background:var(--bg); border-radius:12px;
  padding:4px; margin-bottom:24px; gap:4px;
}
.tab-btn {
  flex:1; padding:10px; border:none; border-radius:10px;
  background:transparent; color:var(--muted);
  font-family:'Poppins',sans-serif; font-size:14px; font-weight:600;
  cursor:pointer; transition:.2s;
}
.tab-btn.active { background:var(--primary); color:#000; }

.form-group { margin-bottom:16px; }
.form-group label { display:block; font-size:12px; color:var(--muted); margin-bottom:6px; font-weight:600; text-transform:uppercase; letter-spacing:.5px; }
.form-group input {
  width:100%; padding:13px 16px;
  background:var(--bg); border:1px solid rgba(255,255,255,.08);
  border-radius:12px; color:var(--text);
  font-family:'Poppins',sans-serif; font-size:14px;
  transition:.2s; outline:none;
}
.form-group input:focus { border-color:var(--primary); box-shadow:0 0 0 3px rgba(0,200,83,.15); }

.btn-primary {
  width:100%; padding:14px;
  background: linear-gradient(135deg,#00c853,#00e676);
  border:none; border-radius:12px;
  color:#000; font-family:'Poppins',sans-serif;
  font-size:15px; font-weight:700; cursor:pointer;
  transition:.2s; margin-top:8px;
}
.btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(0,200,83,.4); }
.btn-primary:active { transform:translateY(0); }
.btn-primary:disabled { opacity:.5; cursor:not-allowed; transform:none; }

.form-note { text-align:center; font-size:12px; color:var(--muted); margin-top:16px; }

/* ══════════════════════════════
   MAIN APP
══════════════════════════════ */
#appScreen { padding-bottom:80px; }

/* Header */
.header {
  background: var(--card);
  border-bottom:1px solid rgba(255,255,255,.06);
  padding:16px 20px;
  position:sticky; top:0; z-index:100;
  backdrop-filter:blur(20px);
}
.header-inner { display:flex; align-items:center; justify-content:space-between; max-width:600px; margin:0 auto; }
.header-logo { font-family:'Baloo Da 2',sans-serif; font-weight:800; font-size:22px; color:var(--primary); }
.header-user { display:flex; align-items:center; gap:10px; }
.avatar {
  width:36px; height:36px; border-radius:50%;
  background:linear-gradient(135deg,#00c853,#7c4dff);
  display:flex; align-items:center; justify-content:center;
  font-weight:700; font-size:15px; color:#fff;
}
.username-text { font-size:13px; font-weight:600; }
.location-badge {
  font-size:10px; padding:2px 8px; border-radius:20px;
  font-weight:600;
}
.loc-bd { background:rgba(0,200,83,.15); color:var(--primary); }
.loc-us { background:rgba(33,150,243,.15); color:#42a5f5; }

/* Balance Card */
.balance-section { padding:20px 16px 0; max-width:600px; margin:0 auto; }
.balance-card {
  background:linear-gradient(135deg,#00c853 0%,#00897b 50%,#1565c0 100%);
  border-radius:24px; padding:28px 24px;
  position:relative; overflow:hidden;
}
.balance-card::before {
  content:'';
  position:absolute; top:-30px; right:-30px;
  width:160px; height:160px; border-radius:50%;
  background:rgba(255,255,255,.08);
}
.balance-card::after {
  content:'';
  position:absolute; bottom:-40px; left:-20px;
  width:120px; height:120px; border-radius:50%;
  background:rgba(255,255,255,.05);
}
.balance-label { font-size:12px; color:rgba(255,255,255,.75); font-weight:600; text-transform:uppercase; letter-spacing:1px; }
.balance-amount { font-size:42px; font-weight:800; color:#fff; margin:4px 0; font-family:'Baloo Da 2',sans-serif; }
.balance-currency { font-size:14px; color:rgba(255,255,255,.85); }
.balance-row { display:flex; gap:16px; margin-top:20px; }
.balance-mini { flex:1; background:rgba(255,255,255,.12); border-radius:12px; padding:10px 14px; }
.balance-mini span { display:block; font-size:10px; color:rgba(255,255,255,.7); }
.balance-mini strong { font-size:16px; color:#fff; font-weight:700; }

/* Today Progress */
.progress-section { padding:16px; max-width:600px; margin:0 auto; }
.section-title { font-size:13px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.8px; margin-bottom:12px; }
.progress-card { background:var(--card); border-radius:16px; padding:16px; border:1px solid rgba(255,255,255,.06); }
.progress-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
.progress-header span { font-size:13px; }
.progress-bar-bg { height:10px; background:var(--bg); border-radius:99px; overflow:hidden; }
.progress-bar-fill { height:100%; border-radius:99px; background:linear-gradient(90deg,#00c853,#69f0ae); transition:width .5s ease; }
.progress-stats { display:flex; gap:12px; margin-top:12px; }
.pstat { flex:1; text-align:center; background:var(--bg); border-radius:10px; padding:8px; }
.pstat span { display:block; font-size:10px; color:var(--muted); }
.pstat strong { font-size:15px; font-weight:700; color:var(--primary); }

/* Ad Zone */
.ad-section { padding:0 16px 12px; max-width:600px; margin:0 auto; }
.ad-label { font-size:10px; color:var(--muted); text-align:center; margin-bottom:6px; }
.ad-box { background:var(--card2); border-radius:12px; overflow:hidden; border:1px solid rgba(255,255,255,.05); display:flex; align-items:center; justify-content:center; min-height:80px; }

/* Tasks */
.tasks-section { padding:0 16px; max-width:600px; margin:0 auto; }
.task-card {
  background:var(--card); border:1px solid rgba(255,255,255,.06);
  border-radius:16px; padding:16px; margin-bottom:12px;
  transition:.2s; cursor:pointer;
  position:relative; overflow:hidden;
}
.task-card:hover { border-color:rgba(0,200,83,.3); transform:translateY(-2px); }
.task-card.locked { opacity:.6; cursor:not-allowed; }
.task-card.completed { border-color:rgba(0,200,83,.4); background:rgba(0,200,83,.05); }
.task-badge {
  position:absolute; top:12px; right:12px;
  font-size:10px; font-weight:700; padding:3px 10px; border-radius:20px;
}
.badge-easy { background:rgba(0,200,83,.15); color:#69f0ae; }
.badge-medium { background:rgba(255,193,7,.15); color:#ffc107; }
.badge-hard { background:rgba(255,23,68,.15); color:#ff6090; }
.badge-done { background:rgba(0,200,83,.2); color:#00c853; }
.task-icon { font-size:28px; margin-bottom:8px; }
.task-title { font-size:15px; font-weight:700; margin-bottom:4px; }
.task-desc { font-size:12px; color:var(--muted); margin-bottom:12px; line-height:1.5; }
.task-footer { display:flex; align-items:center; justify-content:space-between; }
.task-earn { font-size:16px; font-weight:800; color:var(--accent); }
.task-earn small { font-size:10px; font-weight:400; color:var(--muted); }
.task-btn {
  padding:8px 18px; border-radius:10px; border:none;
  font-family:'Poppins',sans-serif; font-size:12px; font-weight:700;
  cursor:pointer; transition:.2s;
}
.task-btn-start { background:var(--primary); color:#000; }
.task-btn-start:hover { background:#00e676; }
.task-btn-done { background:rgba(0,200,83,.15); color:var(--primary); cursor:default; }
.task-btn-locked { background:rgba(255,255,255,.07); color:var(--muted); cursor:not-allowed; }
.task-timer { font-size:11px; color:var(--accent); font-weight:600; margin-top:6px; }

/* Bottom Nav */
.bottom-nav {
  position:fixed; bottom:0; left:0; right:0;
  background:var(--card); border-top:1px solid rgba(255,255,255,.07);
  display:flex; justify-content:space-around; align-items:center;
  padding:10px 0 env(safe-area-inset-bottom);
  z-index:200;
}
.nav-item {
  flex:1; display:flex; flex-direction:column; align-items:center;
  gap:4px; padding:6px; cursor:pointer;
  color:var(--muted); transition:.2s; border:none; background:none;
}
.nav-item.active { color:var(--primary); }
.nav-icon { font-size:22px; }
.nav-label { font-size:10px; font-weight:600; }

/* Sub-screens */
.sub-screen { display:none; padding:16px; max-width:600px; margin:0 auto; }
.sub-screen.active { display:block; }

/* Withdraw */
.withdraw-card { background:var(--card); border-radius:16px; padding:20px; margin-bottom:16px; border:1px solid rgba(255,255,255,.06); }
.withdraw-card h3 { font-size:15px; font-weight:700; margin-bottom:4px; }
.withdraw-card p { font-size:12px; color:var(--muted); margin-bottom:16px; }
.method-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.method-btn {
  padding:14px 10px; background:var(--bg); border:1px solid rgba(255,255,255,.08);
  border-radius:12px; text-align:center; cursor:pointer; transition:.2s;
}
.method-btn:hover { border-color:var(--primary); }
.method-btn .micon { font-size:24px; margin-bottom:4px; }
.method-btn span { display:block; font-size:12px; font-weight:600; }
.method-btn small { font-size:10px; color:var(--muted); }

/* History */
.history-item {
  display:flex; align-items:center; gap:12px;
  background:var(--card); border-radius:12px; padding:14px;
  margin-bottom:8px; border:1px solid rgba(255,255,255,.05);
}
.hist-icon { width:40px; height:40px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
.hist-info { flex:1; }
.hist-info strong { display:block; font-size:13px; font-weight:600; }
.hist-info small { font-size:11px; color:var(--muted); }
.hist-amount { font-size:14px; font-weight:700; color:var(--primary); }

/* Profile */
.profile-header { text-align:center; padding:24px 16px; }
.profile-avatar {
  width:80px; height:80px; border-radius:50%;
  background:linear-gradient(135deg,#00c853,#7c4dff);
  display:flex; align-items:center; justify-content:center;
  font-size:32px; font-weight:700; margin:0 auto 12px;
  box-shadow:0 8px 24px rgba(0,200,83,.3);
}
.stat-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:20px; }
.stat-box { background:var(--card); border-radius:12px; padding:14px; text-align:center; border:1px solid rgba(255,255,255,.06); }
.stat-box strong { display:block; font-size:20px; font-weight:800; color:var(--primary); }
.stat-box span { font-size:10px; color:var(--muted); }

/* Toast */
.toast {
  position:fixed; bottom:90px; left:50%; transform:translateX(-50%) translateY(20px);
  background:var(--primary); color:#000; padding:12px 24px;
  border-radius:12px; font-weight:700; font-size:14px;
  opacity:0; transition:.3s; z-index:999; white-space:nowrap;
}
.toast.show { opacity:1; transform:translateX(-50%) translateY(0); }

/* Modal */
.modal-overlay {
  position:fixed; inset:0; background:rgba(0,0,0,.7);
  display:flex; align-items:center; justify-content:center;
  z-index:300; padding:20px; opacity:0; pointer-events:none; transition:.3s;
}
.modal-overlay.show { opacity:1; pointer-events:all; }
.modal-box {
  background:var(--card); border-radius:24px; padding:28px;
  width:100%; max-width:360px;
  border:1px solid rgba(0,200,83,.2);
  transform:scale(.9); transition:.3s;
}
.modal-overlay.show .modal-box { transform:scale(1); }
.modal-box h3 { font-size:18px; font-weight:800; margin-bottom:8px; }
.modal-box p { font-size:13px; color:var(--muted); margin-bottom:20px; line-height:1.6; }
.modal-actions { display:flex; gap:10px; }
.btn-cancel {
  flex:1; padding:12px; background:var(--bg); border:1px solid rgba(255,255,255,.1);
  border-radius:12px; color:var(--text); font-family:'Poppins',sans-serif;
  font-size:14px; font-weight:600; cursor:pointer;
}
.btn-confirm {
  flex:2; padding:12px; background:var(--primary); border:none;
  border-radius:12px; color:#000; font-family:'Poppins',sans-serif;
  font-size:14px; font-weight:700; cursor:pointer;
}

.spinner { display:inline-block; width:18px; height:18px; border:3px solid rgba(0,0,0,.2); border-top:3px solid #000; border-radius:50%; animation:spin .7s linear infinite; vertical-align:middle; margin-right:6px; }
@keyframes spin { to { transform:rotate(360deg); } }

/* Referral */
.ref-box { background:var(--card2); border:2px dashed rgba(0,200,83,.3); border-radius:16px; padding:20px; text-align:center; margin-bottom:16px; }
.ref-code { font-size:28px; font-weight:800; color:var(--accent); letter-spacing:4px; margin:10px 0; font-family:'Baloo Da 2',sans-serif; }

/* Responsive */
@media(max-width:380px) {
  .balance-amount { font-size:34px; }
  .task-title { font-size:13px; }
}
</style>
</head>
