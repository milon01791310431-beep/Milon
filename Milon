// ══════════════════════════════════════════════════
// WITHDRAW
// ══════════════════════════════════════════════════
function openWithdrawModal(method) {
  currentWithdrawMethod = method;
  document.getElementById('modalTitle').textContent = method + '-এ উইথড্র';
  document.getElementById('modalBody').textContent = 'আপনার ' + method + ' একাউন্ট নম্বর ও পরিমাণ দিন।';
  document.getElementById('modalAcc').value = '';
  document.getElementById('modalAmt').value = '';
  document.getElementById('withdrawModal').classList.add('show');
}

function closeModal() {
  document.getElementById('withdrawModal').classList.remove('show');
}

async function submitWithdraw() {
  const acc = document.getElementById('modalAcc').value.trim();
  const amt = parseFloat(document.getElementById('modalAmt').value);
  const minAmt = currentWithdrawMethod === 'PayPal' ? 5 : 1;
  if (!acc) { showToast('একাউন্ট নম্বর দিন'); return; }
  if (!amt || amt < minAmt) { showToast('সর্বনিম্ন $' + minAmt + ' উইথড্র করুন'); return; }
  if ((userData.balance||0) < amt) { showToast('পর্যাপ্ত ব্যালেন্স নেই'); return; }

  try {
    await db.ref('users/' + currentUser.uid).update({
      balance: firebase.database.ServerValue.increment(-amt)
    });
    await db.ref('withdrawals/' + currentUser.uid).push({
      method: currentWithdrawMethod, account: acc,
      amount: amt, status: 'pending', timestamp: Date.now()
    });
    await db.ref('transactions/' + currentUser.uid).push({
      type: 'withdraw', amount: -amt,
      note: currentWithdrawMethod + '-এ উইথড্র অনুরোধ',
      timestamp: Date.now()
    });
    closeModal();
    showToast('✅ উইথড্র অনুরোধ জমা হয়েছে!');
    loadWithdrawHistory();
  } catch(e) {
    showToast('❌ উইথড্র ব্যর্থ হয়েছে');
  }
}

async function loadWithdrawHistory() {
  const snap = await db.ref('withdrawals/' + currentUser.uid).orderByChild('timestamp').limitToLast(10).once('value');
  const cont = document.getElementById('withdrawHistory');
  if (!snap.exists()) { cont.innerHTML = '<div style="text-align:center;color:var(--muted);font-size:13px;padding:16px;">কোনো ইতিহাস নেই</div>'; return; }
  const items = [];
  snap.forEach(c => items.unshift({...c.val(), key:c.key}));
  const statusMap = { pending:'⏳ অপেক্ষায়', approved:'✅ অনুমোদিত', rejected:'❌ বাতিল' };
  cont.innerHTML = items.map(w => `
    <div class="history-item">
      <div class="hist-icon" style="background:rgba(255,193,7,.1);">💸</div>
      <div class="hist-info">
        <strong>${w.method} – ${w.account}</strong>
        <small>${new Date(w.timestamp).toLocaleDateString('bn-BD')} | ${statusMap[w.status]||'⏳'}</small>
      </div>
      <div class="hist-amount" style="color:#ff6090;">-$${w.amount.toFixed(2)}</div>
    </div>
  `).join('');
}

// ══════════════════════════════════════════════════
// HISTORY
// ══════════════════════════════════════════════════
async function loadHistory() {
  const snap = await db.ref('transactions/' + currentUser.uid).orderByChild('timestamp').limitToLast(30).once('value');
  const list = document.getElementById('historyList');
  if (!snap.exists()) { list.innerHTML = '<div style="text-align:center;color:var(--muted);font-size:13px;padding:32px;">কোনো লেনদেন নেই</div>'; return; }
  const items = [];
  snap.forEach(c => items.unshift(c.val()));
  const icons = { task:'📋', ad:'📺', popup:'🔗', referral:'👥', withdraw:'💸', bonus:'🏆', browse:'🌐', survey:'📊', form:'📝' };
  list.innerHTML = items.map(t => `
    <div class="history-item">
      <div class="hist-icon" style="background:rgba(0,200,83,.1);">${icons[t.type]||'💰'}</div>
      <div class="hist-info">
        <strong>${t.note||'লেনদেন'}</strong>
        <small>${new Date(t.timestamp).toLocaleDateString('bn-BD')} ${new Date(t.timestamp).toLocaleTimeString('bn-BD')}</small>
      </div>
      <div class="hist-amount" style="color:${t.amount<0?'#ff6090':'var(--primary)'};">${t.amount>0?'+':''}$${Math.abs(t.amount).toFixed(3)}</div>
    </div>
  `).join('');
}

// ══════════════════════════════════════════════════
// NAVIGATION
// ══════════════════════════════════════════════════
function switchTab2(id, btn) {
  document.querySelectorAll('.sub-screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
  if (id === 'tabHistory') loadHistory();
  if (id === 'tabWithdraw') loadWithdrawHistory();
}

