  if (pass.length < 6) { showToast('পাসওয়ার্ড কমপক্ষে ৬ অক্ষর'); return; }
  const btn = document.getElementById('registerBtn');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span>তৈরি হচ্ছে...';
  try {
    const email = phone + '@earnpro.app';
    const uc = await firebase.auth().createUserWithEmailAndPassword(email, pass);
    const uid = uc.user.uid;
    const myRefCode = 'EP' + uid.slice(0,6).toUpperCase();
    const todayKey = getTodayKey();
    await db.ref('users/' + uid).set({
      name, phone, refCode: myRefCode,
      balance: 0, totalEarned: 0, totalTasks: 0,
      referralEarned: 0, referralCount: 0,
      registeredAt: Date.now(),
      days: { [todayKey]: { earned: 0, tasks: 0 } }
    });
    // Handle referral
    if (refCode) {
      const snap = await db.ref('users').orderByChild('refCode').equalTo(refCode).once('value');
      if (snap.exists()) {
        const refUid = Object.keys(snap.val())[0];
        await db.ref('users/' + refUid).update({
          balance: firebase.database.ServerValue.increment(0.50),
          totalEarned: firebase.database.ServerValue.increment(0.50),
          referralEarned: firebase.database.ServerValue.increment(0.50),
          referralCount: firebase.database.ServerValue.increment(1)
        });
        await db.ref('transactions/' + refUid).push({
          type: 'referral', amount: 0.50,
          note: name + '-এর রেফারেল বোনাস',
          timestamp: Date.now()
        });
      }
    }
    showToast('✅ একাউন্ট তৈরি হয়েছে!');
  } catch(e) {
    let msg = 'রেজিস্ট্রেশন ব্যর্থ হয়েছে';
    if (e.code === 'auth/email-already-in-use') msg = 'এই নম্বর আগেই রেজিস্টার্ড';
    showToast('❌ ' + msg);
    btn.disabled = false; btn.textContent = 'একাউন্ট তৈরি করুন';
  }
}

